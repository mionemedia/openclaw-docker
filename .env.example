# OpenClaw Docker Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!

# OpenClaw Gateway Token
# Generate a secure random token: openssl rand -base64 48
OPENCLAW_GATEWAY_TOKEN=your_secure_gateway_token_here

# OpenRouter API Key
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here

# Optional: Gemini API Key (for image generation)
# Get from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: OpenAI API Key (for image fallback)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
